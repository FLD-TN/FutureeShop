@using MTKPM_FE.Models
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation
@inject myContext Db

@code {
    private string searchTerm = string.Empty;
    private int? categoryId;
    private decimal? minPrice;
    private decimal? maxPrice;
    private string sortBy = string.Empty;
    private List<Category> categories = new();

    protected override void OnInitialized()
    {
        // load categories
        categories = Db.tbl_category.ToList();

        // read current querystring to initialize values
        var uri = new Uri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("searchTerm", out var s)) searchTerm = s.ToString();
        if (query.TryGetValue("categoryId", out var c) && int.TryParse(c, out var cid)) categoryId = cid;
        if (query.TryGetValue("minPrice", out var mp) && decimal.TryParse(mp, out var dmp)) minPrice = dmp;
        if (query.TryGetValue("maxPrice", out var xp) && decimal.TryParse(xp, out var dxp)) maxPrice = dxp;
        if (query.TryGetValue("sortBy", out var sb)) sortBy = sb.ToString();
    }

    private void Apply()
    {
        var qs = new Dictionary<string, string?>();
        if (!string.IsNullOrWhiteSpace(searchTerm)) qs["searchTerm"] = searchTerm;
        if (categoryId.HasValue) qs["categoryId"] = categoryId.Value.ToString();
        if (minPrice.HasValue) qs["minPrice"] = minPrice.Value.ToString();
        if (maxPrice.HasValue) qs["maxPrice"] = maxPrice.Value.ToString();
        if (!string.IsNullOrWhiteSpace(sortBy)) qs["sortBy"] = sortBy;

        var url = QueryHelpers.AddQueryString("/Home/AllProducts", qs!);
        Navigation.NavigateTo(url);
    }
}

<div class="filter-component p-3 bg-white rounded">
    <div class="mb-2">
        <input class="form-control" placeholder="Tìm kiếm" @bind="searchTerm" />
    </div>
    <div class="mb-2">
        <select class="form-select" @bind="categoryId">
            <option value="">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.category_id">@c.category_name</option>
            }
        </select>
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6"><input type="number" step="0.01" class="form-control" placeholder="Giá từ" @bind="minPrice" /></div>
        <div class="col-6"><input type="number" step="0.01" class="form-control" placeholder="Giá đến" @bind="maxPrice" /></div>
    </div>
    <div class="mb-2">
        <select class="form-select" @bind="sortBy">
            <option value="">Sắp xếp</option>
            <option value="price_asc">Giá tăng dần</option>
            <option value="price_desc">Giá giảm dần</option>
            <option value="name">Tên</option>
            <option value="sold">Bán chạy</option>
        </select>
    </div>
    <div class="d-grid">
        <button class="btn btn-primary" @onclick="Apply">Áp dụng bộ lọc</button>
    </div>
</div>
