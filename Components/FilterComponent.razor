@using System.Net.Http.Json
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="filter-sidebar">
    <h5 class="filter-title mb-4">Bộ lọc</h5>
    
    <div class="filter-section">
        <h6 class="filter-section-title">Danh mục</h6>
        <div class="filter-checkboxes">
            @foreach (var category in categories)
            {
                <label class="filter-checkbox">
                    <input type="checkbox" 
                           checked="@category.Selected"
                           @onchange="@(() => ToggleCategory(category))" />
                    <span>@category.Name</span>
                </label>
            }
        </div>
    </div>
    
    <div class="filter-section">
        <h6 class="filter-section-title">Khoảng giá</h6>
        <div class="price-range">
            <input type="number" 
                   class="form-control mb-2" 
                   placeholder="Tối thiểu" 
                   @bind="minPrice" />
            <input type="number" 
                   class="form-control" 
                   placeholder="Tối đa" 
                   @bind="maxPrice" />
        </div>
    </div>
    
    <div class="filter-section">
        <h6 class="filter-section-title">Đánh giá</h6>
        <div class="rating-filters">
            @for (int i = 5; i >= 1; i--)
            {
                <label class="rating-filter">
                    <input type="radio" 
                           name="rating" 
                           value="@i" 
                           checked="@(selectedRating == i)"
                           @onchange="@(() => SelectRating(i))" />
                    <span>@i <i class="fas fa-star text-warning"></i> trở lên</span>
                </label>
            }
        </div>
    </div>
    
    <button class="btn btn-primary-custom w-100 mt-4" @onclick="ApplyFilters">
        Áp dụng bộ lọc
    </button>
    
    <button class="btn btn-outline-primary-custom w-100 mt-2" @onclick="ResetFilters">
        Xóa bộ lọc
    </button>
</div>

<style>
    .filter-sidebar {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .filter-title {
        font-weight: 700;
        color: #2C3E50;
        border-bottom: 2px solid var(--primary-color);
        padding-bottom: 12px;
    }
    
    .filter-section {
        margin-bottom: 24px;
    }
    
    .filter-section-title {
        font-weight: 600;
        color: #2C3E50;
        margin-bottom: 12px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .filter-checkboxes {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    .filter-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        padding: 8px;
        border-radius: 8px;
        transition: background 0.2s;
    }
    
    .filter-checkbox:hover {
        background: #f8f9fa;
    }
    
    .filter-checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }
    
    .price-range input {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 10px;
    }
    
    .price-range input:focus {
        border-color: var(--primary-color);
        outline: none;
    }
    
    .rating-filters {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    .rating-filter {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        padding: 8px;
        border-radius: 8px;
        transition: background 0.2s;
    }
    
    .rating-filter:hover {
        background: #f8f9fa;
    }
</style>

@code {
    private List<CategoryFilter> categories = new()
    {
        new() { Name = "Bàn ghế", Value = "banghe", Selected = false },
        new() { Name = "Tủ kệ", Value = "tuke", Selected = false },
        new() { Name = "Sofa", Value = "sofa", Selected = false },
        new() { Name = "Giường", Value = "giuong", Selected = false },
        new() { Name = "Đèn", Value = "den", Selected = false },
        new() { Name = "Đồ trang trí", Value = "dotrangtri", Selected = false }
    };
    
    private int? minPrice;
    private int? maxPrice;
    private int? selectedRating;
    
    private void ToggleCategory(CategoryFilter category)
    {
        category.Selected = !category.Selected;
    }
    
    private void SelectRating(int rating)
    {
        selectedRating = selectedRating == rating ? null : rating;
    }
    
    private void ApplyFilters()
    {
        var selectedCategories = categories.Where(c => c.Selected).Select(c => c.Value).ToList();
        var queryParams = new List<string>();
        
        if (selectedCategories.Any())
        {
            queryParams.AddRange(selectedCategories.Select(c => $"categories={c}"));
        }
        
        if (minPrice.HasValue)
            queryParams.Add($"minPrice={minPrice.Value}");
        
        if (maxPrice.HasValue)
            queryParams.Add($"maxPrice={maxPrice.Value}");
        
        if (selectedRating.HasValue)
            queryParams.Add($"ratings={selectedRating.Value}");
        
        var queryString = queryParams.Any() ? "?" + string.Join("&", queryParams) : "";
        Navigation.NavigateTo($"/Home/AllProducts{queryString}");
    }
    
    private void ResetFilters()
    {
        foreach (var category in categories)
        {
            category.Selected = false;
        }
        minPrice = null;
        maxPrice = null;
        selectedRating = null;
        Navigation.NavigateTo("/Home/AllProducts");
    }
    
    private class CategoryFilter
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
        public bool Selected { get; set; }
    }
}

