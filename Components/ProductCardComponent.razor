@using MTKPM_FE.Models
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="product-card animate-fade-in">
    <a href="/Home/ProductDetail/@Product.product_id" class="text-decoration-none">
        <img src="/product_images/@Product.product_image" 
             class="product-card-img" 
             alt="@Product.product_name" 
             loading="lazy" />
    </a>
    
    <div class="product-card-body">
        <div class="product-rating mb-2">
            <i class="fas fa-star"></i>
            <span>@Product.product_rating.ToString("0.0")</span>
            <span class="text-muted ms-2">(@Product.product_review_count)</span>
            <span class="ms-auto text-muted small">Đã bán: @Product.product_stock</span>
        </div>
        
        <h6 class="product-card-title">
            @Product.product_name
        </h6>
        
        <div class="mb-3">
            @if (Product.product_discount_price.HasValue)
            {
                var discountPercent = (int)Math.Round(100.0 * (Product.product_price - Product.product_discount_price.Value) / Product.product_price);
                <span class="product-price">
                    @Product.product_discount_price.Value.ToString("N0") ₫
                </span>
                <span class="product-price-old">
                    @Product.product_price.ToString("N0") ₫
                </span>
                <span class="product-badge">-@discountPercent%</span>
            }
            else
            {
                <span class="product-price">
                    @Product.product_price.ToString("N0") ₫
                </span>
            }
        </div>
        
        <div class="d-grid gap-2">
            <a href="/Home/ProductDetail/@Product.product_id" 
               class="btn btn-outline-primary-custom">
                <i class="fas fa-eye me-1"></i> Chi tiết
            </a>
            <button class="btn btn-primary-custom" @onclick="AddToCart">
                <i class="fas fa-cart-plus me-1"></i> Thêm vào giỏ
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Product Product { get; set; } = new();
    
    private async Task AddToCart()
    {
        // Chuyển hướng đến action AddToCart
        Navigation.NavigateTo($"/Cart/AddToCart?productId={Product.product_id}");
    }
}

