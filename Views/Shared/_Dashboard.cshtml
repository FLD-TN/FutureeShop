@{
	Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 260px;
            --header-height: 70px;
            --primary-color: #3b82f6;
            --bg-body: #f1f5f9;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            overflow-x: hidden; /* Ẩn thanh cuộn ngang nếu bị tràn */
        }

        /* === 1. SIDEBAR CONFIG === */
        @@media (min-width: 992px) {
            #sidebarOffcanvas {
                position: fixed;
                top: 0;
                bottom: 0;
                left: 0;
                z-index: 1040;
                transform: none;
                visibility: visible !important;
            }
            
            /* Đẩy nội dung chính sang phải */
            .main-content-wrapper {
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width)); /* Quan trọng: Đảm bảo nội dung không bị tràn */
            }

            /* Sửa lỗi Topbar bị hụt */
            .top-header {
                left: var(--sidebar-width);
                right: 0; /* Neo chặt vào bên phải */
                width: auto; /* Tự động tính toán chiều rộng */
            }
        }

        /* === 2. HEADER CONFIG === */
        .top-header {
            height: var(--header-height);
            background: #ffffff;
            position: fixed;
            top: 0;
            right: 0;
            left: 0; /* Mặc định trên mobile */
            z-index: 1030;
            padding: 0 1.5rem;
            transition: all 0.3s;
        }

        /* === 3. CONTENT AREA === */
        main {
            padding: 2rem;
            margin-top: var(--header-height);
        }

        /* === 4. STYLE FIXES === */
        /* Sửa lỗi icon và chữ không thẳng hàng */
        .nav-link {
            display: flex !important; /* Bắt buộc dùng flex */
            align-items: center !important; /* Căn giữa dọc */
            white-space: nowrap; /* Không cho xuống dòng */
        }
        
        .nav-link:hover { 
            background: rgba(255,255,255,0.1); 
            color: #fff !important; 
            transform: translateX(5px);
            transition: 0.3s;
        }
        
        .active-menu {
            background: var(--primary-color) !important;
            color: #fff !important;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }

        .header-icon {
            width: 40px; height: 40px; border-radius: 50%; background: #f8fafc; 
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; border: 1px solid #e2e8f0;
        }
        .user-avatar { width: 40px; height: 40px; border-radius: 10px; object-fit: cover; }
    </style>
</head>
<body>

    @await Html.PartialAsync("_SidebarAdmin")

    <div class="main-content-wrapper">
        @await Html.PartialAsync("_TopBarAdmin")

        <main>
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>