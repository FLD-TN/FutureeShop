@using MTKPM_FE.Models

@{
    var title = ViewData["Title"] as string ?? "Nội Thất Xinh";
    var description = ViewData["Description"] as string ?? "Shop nội thất cao cấp";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title – Nội Thất Xinh</title>
    <meta name="description" content="@description" />
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    <meta property="og:image" content="~/images/og-image.jpg" />

    <!-- Bootstrap CSS -->
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    </environment>

    <!-- Font Awesome -->
    <script defer
            src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>

    <!-- Site CSS -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    <!-- Google Fonts -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css?family=Poppins:400,500,600,700&display=swap" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <partial name="_UserHeader" />

    <main role="main">
        @RenderBody()
    </main>

    <!-- Modal cảnh báo -->
    @RenderSection("Modals", required: false)
    <div class="modal fade" id="comingSoonModal" tabindex="-1" aria-labelledby="comingSoonLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center rounded-4 p-4">
                <button type="button"
                        class="btn-close position-absolute top-0 end-0 m-3"
                        data-bs-dismiss="modal"
                        aria-label="Close"></button>
                <img src="~/images/warning.png"
                     alt="Cảnh báo"
                     class="mx-auto mb-3"
                     style="width: 50px;" />
                <h5 id="comingSoonLabel" class="fw-semibold fs-6">Tính năng đang được phát triển</h5>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <environment include="Development">
        <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </environment>
    <partial name="_Footer" />

    <!-- Blazor Server Scripts -->
    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // 1. Tự động sinh giao diện Toast Message nếu chưa có
        if (!document.getElementById('toast-message')) {
            const toastHtml = `
            <div id="toast-message" class="toast align-items-center text-white border-0 position-fixed top-0 end-0 p-3 m-3" style="z-index: 9999; display:none;">
                <div class="d-flex">
                    <div class="toast-body fw-bold" id="toast-body-content" style="font-size: 16px;"></div>
                </div>
            </div>`;
            document.body.insertAdjacentHTML('beforeend', toastHtml);
        }

        // Hàm hiển thị Toast
        function showGlobalToast(message, isError = false) {
            const toastEl = document.getElementById('toast-message');
            const toastBody = document.getElementById('toast-body-content');
            toastBody.innerText = message;
            toastEl.className = `toast align-items-center text-white border-0 position-fixed top-0 end-0 p-3 m-3 ${isError ? 'bg-danger' : 'bg-success'}`;
            toastEl.style.display = 'block';
            setTimeout(() => { toastEl.style.display = 'none'; }, 3000); // 3 giây tự tắt
        }

        // 2. Bắt sự kiện "Thêm vào giỏ" ở toàn bộ website
        document.addEventListener('click', function(e) {
            // Áp dụng cho nút ở trang danh sách sản phẩm (.btn-add-cart)
            if (e.target.closest('.btn-add-cart')) {
                e.preventDefault();
                const btn = e.target.closest('.btn-add-cart');
                const productId = btn.getAttribute('data-id'); 

                fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `productId=${productId}&quantity=1`
                })
                .then(res => res.json())
                .then(data => showGlobalToast(data.message, !data.success));
            }

            // Áp dụng cho nút ở trang chi tiết sản phẩm (#btn-add-to-cart-detail)
            else if (e.target.closest('#btn-add-to-cart-detail')) {
                e.preventDefault();
                const btn = e.target.closest('#btn-add-to-cart-detail');
                const productId = btn.getAttribute('data-id');
                const qty = document.getElementById('quantity-detail').value;

                fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `productId=${productId}&quantity=${qty}`
                })
                .then(res => res.json())
                .then(data => showGlobalToast(data.message, !data.success));
            }
        });
    </script>
</body>
</html>
