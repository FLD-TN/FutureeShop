@*
  Premium footer for furniture store
*@
<footer class="mt-5" style="background:#4b3b2a; color:#fff;">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-center mb-3">
                    <svg class="svg-inline--fa fa-couch me-2" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="couch" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" data-fa-i2svg=""><path fill="currentColor" d="M64 160C64 89.3 121.3 32 192 32H448c70.7 0 128 57.3 128 128v33.6c-36.5 7.4-64 39.7-64 78.4v48H128V272c0-38.7-27.5-71-64-78.4V160zM544 272c0-20.9 13.4-38.7 32-45.3c5-1.8 10.4-2.7 16-2.7c26.5 0 48 21.5 48 48V448c0 17.7-14.3 32-32 32H576c-17.7 0-32-14.3-32-32H96c0 17.7-14.3 32-32 32H32c-17.7 0-32-14.3-32-32V272c0-26.5 21.5-48 48-48c5.6 0 11 1 16 2.7c18.6 6.6 32 24.4 32 45.3v48 32h32H512h32V320 272z"></path></svg>
                    <span class="ms-3 fw-semibold" style="font-size:1.1rem;">Nội Thất Xinh</span>
                </div>
                <p class="mb-2 opacity-75">Không gian sống đẳng cấp – Biến ngôi nhà thành tổ ấm của bạn.</p>
                <ul class="list-unstyled small opacity-75 mb-0">
                    <li>Địa chỉ: 806 Lê Quang Đạo, Hóc Môn Commune, Ho Chi Minh City</li>
                    <li>Hotline: 0123456789</li>
                    <li>Email: noithatxinh@gmail.com</li>
                </ul>
            </div>
            <div class="col-6 col-md-2">
                <div class="fw-semibold text-uppercase mb-3">Danh mục</div>
                <ul class="list-unstyled">
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="@Url.Action("AllProducts","Home")">Sản phẩm</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="@Url.Action("CategoryProducts","Home", new { category = "BanGhe" })">Bàn ghế</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="@Url.Action("CategoryProducts","Home", new { category = "Sofa" })">Sofa</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="@Url.Action("CategoryProducts","Home", new { category = "Giuong" })">Giường</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-semibold text-uppercase mb-3">Chính sách</div>
                <ul class="list-unstyled">
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="#">Bảo hành</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="#">Đổi trả</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="#">Vận chuyển</a></li>
                    <li class="mb-2"><a class="text-decoration-none" style="color:#fff; opacity:.9;" href="#">Bảo mật</a></li>
                </ul>
            </div>
            <div class="col-12 col-md-3">
                <div class="fw-semibold text-uppercase mb-3">Theo dõi</div>
                <div class="d-flex gap-3 fs-5">
                    <a class="text-white" href="https://facebook.com" aria-label="Facebook"><i class="fab fa-facebook"></i></a>
                    <a class="text-white" href="https://www.instagram.com" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    <a class="text-white" href="https://www.youtube.com" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
        <hr class="mt-4" style="border-color: rgba(255,255,255,.2);" />
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-2 small" style="opacity:.85;">
            <div>© @DateTime.Now.Year Nội Thất Xinh. All rights reserved.</div>
            <div class="mt-2 mt-md-0">Thiết kế bởi Nội Thất Xinh</div>
        </div>
    </div>
</footer>

