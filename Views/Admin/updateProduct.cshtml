@model MTKPM_FE.Models.Product
@using MTKPM_FE.Models
@{
    var categories = ViewData["category"] as List<Category>;
}

<form method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="product_id" />

    <label class="fw-bold mt-2">Product Name:</label>
    <input type="text" asp-for="product_name" class="form-control my-2" />
    <span asp-validation-for="product_name" class="text-danger fw-bold"></span>

    <label class="fw-bold mt-2">Price:</label>
    <input type="number" asp-for="product_price" class="form-control my-2" />
    <span asp-validation-for="product_price" class="text-danger fw-bold"></span>

    <label class="fw-bold mt-2">Discount Price:</label>
    <input type="number" asp-for="product_discount_price" class="form-control my-2" />

    <label class="fw-bold mt-2">Rating:</label>
    <input type="text" asp-for="product_rating" class="form-control my-2" />

    <label class="fw-bold mt-2">Review Count:</label>
    <input type="number" asp-for="product_review_count" class="form-control my-2" />

    <label class="fw-bold mt-2">Stock:</label>
    <input type="number" asp-for="product_stock" class="form-control my-2" />

    <label class="fw-bold mt-2">Description:</label>
    <input type="text" asp-for="product_description" class="form-control my-2" />

    <label class="fw-bold mt-2">Category:</label>
    <select asp-for="cat_id" class="form-control my-2">
        @foreach (var cat in categories)
        {
            <option value="@cat.category_id">@cat.category_name</option>
        }
    </select>

    <input type="submit" value="Update Product" class="form-control my-3 btn btn-primary" />
</form>

<hr />
<form method="post" asp-action="ChangeProductImage" enctype="multipart/form-data">
    <input type="hidden" name="product_id" value="@Model.product_id" />
    <div class="text-center">
        <img src="@("~/product_images/" + Model.product_image)" asp-append-version="true" style="width:250px; height:250px" class="rounded shadow my-3" /><br>
        <input type="file" name="product_image" class="form-control mb-2" />
        <input type="submit" value="Change Image" class="btn btn-warning" />
    </div>
</form>