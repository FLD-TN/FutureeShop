@{
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 fw-bold text-dark">Tổng Quan Hệ Thống</h2>
        <button class="btn btn-primary rounded-3 shadow-sm">
            <i class="bi bi-download me-2"></i>Xuất Báo Cáo
        </button>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 border-start border-primary border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">Sản Phẩm</div>
                            <div class="h4 mb-0 fw-bold text-dark">@ViewBag.ProductCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-box fs-1 text-primary opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 border-start border-success border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1">Doanh Thu Tháng</div>
                            <div class="h4 mb-0 fw-bold text-dark">@String.Format("{0:N0}", ViewBag.MonthlyRevenue ?? 0) ₫</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-currency-dollar fs-1 text-success opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 fw-bold text-primary">Biểu Đồ Doanh Thu</h6>
                </div>
                <div class="card-body">
                    <div style="height: 350px;"><canvas id="revenueChart"></canvas></div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 fw-bold text-primary">Phân Bổ Dữ Liệu</h6>
                </div>
                <div class="card-body">
                    <div style="height: 350px;"><canvas id="distributionChart"></canvas></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Cấu hình Biểu đồ đường (Revenue)
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyLabels)),
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: @Html.Raw(Json.Serialize(ViewBag.MonthlyData)),
                    borderColor: '#3b82f6',
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(59, 130, 246, 0.1)'
                }]
            },
            options: { maintainAspectRatio: false }
        });

        // Cấu hình Biểu đồ tròn (Distribution)
        const ctxDist = document.getElementById('distributionChart').getContext('2d');
        new Chart(ctxDist, {
            type: 'doughnut',
            data: {
                labels: ['Sản phẩm', 'Danh mục', 'Khách hàng'],
                datasets: [{
                    data: [@ViewBag.ProductCount, @ViewBag.CategoryCount, @ViewBag.CustomerCount],
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b']
                }]
            },
            options: { maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
    </script>
}