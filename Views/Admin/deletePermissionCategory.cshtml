@model MTKPM_FE.Models.Category

<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase text-danger" style="letter-spacing:4px">
        Bạn có chắc chắn muốn xóa danh mục này không?
    </h2>
</div>

<div class="row">
    <div class="col-md-2"></div>

    <div class="col-md-8">
        <ul class="list-group mb-4">
            <li class="list-group-item">
                <strong>Category Id:</strong> @Model.category_id
            </li>
            <li class="list-group-item">
                <strong>Category Name:</strong> @Model.category_name
            </li>
        </ul>

        <div class="text-center">
            <!-- Form POST đúng chuẩn để gọi action DeleteCategory -->
            <form asp-action="DeleteCategory"
                  asp-controller="Admin"
                  asp-route-id="@Model.category_id"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger me-2">
                    <i class="fas fa-trash-alt"></i> Delete Category
                </button>
            </form>

            <a asp-action="FetchCategory"
               asp-controller="Admin"
               class="btn btn-warning">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="col-md-2"></div>
</div>
