@model IEnumerable<MTKPM_FE.Models.Blog>
@{
    ViewData["Title"] = "Quản lý Blog";
}

<div class="container-fluid px-4">
    <h2 class="mt-4">@ViewData["Title"]</h2>

    <div class="mb-4">
        <a asp-action="CreateBlog" asp-controller="Admin" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Tạo bài viết mới
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            Danh sách bài viết
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="datatablesSimple" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width: 15%;">Ảnh đại diện</th>
                            <th>Tiêu đề</th>
                            <th style="width: 15%;">Ngày tạo</th>
                            <th style="width: 15%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="~/blog_images/@item.blog_image" alt="Ảnh blog" class="img-fluid rounded" style="max-height: 80px; object-fit: cover;" />
                                    </td>
                                    <td>@item.blog_title</td>
                                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a asp-action="EditBlog" asp-route-id="@item.blog_id" class="btn btn-sm btn-warning mb-1" title="Sửa"><i class="fas fa-edit"></i></a>
                                        <a href="#" class="btn btn-sm btn-danger mb-1" title="Xóa (sắp có)"><i class="fas fa-trash"></i></a>
                                        <a href="@(string.IsNullOrEmpty(item.slug) ? "#" : $"/blog/{item.slug}")" target="_blank" class="btn btn-sm btn-info mb-1 @(string.IsNullOrEmpty(item.slug) ? "disabled" : "")" title="Xem"><i class="fas fa-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">Chưa có bài viết nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>