@model Customer
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">Cập nhật Người Dùng</h2>
</div>
<div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-8">
        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="customer_id" />

            <label class="fw-bold mt-2">Họ Tên:</label>
            <input type="text" asp-for="customer_name" class="form-control my-2" required />
            <span asp-validation-for="customer_name" class="text-danger fw-bold"></span>

            <label class="fw-bold mt-2">Số điện thoại:</label>
            <input type="text" asp-for="customer_phone" class="form-control my-2" required />
            <span asp-validation-for="customer_phone" class="text-danger fw-bold"></span>

            <label class="fw-bold mt-2">Email:</label>
            <input type="text" asp-for="customer_email" class="form-control my-2" required />
            <span asp-validation-for="customer_email" class="text-danger fw-bold"></span>

            <label class="fw-bold mt-2">Mật khẩu:</label>
            <input type="text" asp-for="customer_password" class="form-control my-2" required />

            <label class="fw-bold mt-2">Giới tính:</label>
            <input type="text" asp-for="customer_gender" class="form-control my-2" />

            <label class="fw-bold mt-2">Địa chỉ:</label>
            <input type="text" asp-for="customer_address" class="form-control my-2" />

            <input type="submit" value="Cập nhật" class="btn btn-warning w-100 my-4 fw-bold" />
        </form>
    </div>
</div>