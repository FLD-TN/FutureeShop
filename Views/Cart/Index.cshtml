@model List<MTKPM_FE.Models.CartItemViewModel>
@{
	ViewData["Title"] = "Giỏ hàng của bạn";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
	<style>
		/* Định dạng chung cho các nút icon tròn */
		.btn-icon {
			width: 2.4rem;
			height: 2.4rem;
			padding: 0;
			border-radius: 50%;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			font-size: 1rem;
			transition: transform .1s ease, box-shadow .1s ease;
		}

			/* Hover nâng nhẹ và đổ bóng */
			.btn-icon:hover {
				transform: scale(1.1);
				box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.15);
				color: #fff;
			}

		/* Hover cho outline buttons để nền thành màu chủ đạo */
		.btn-outline-success.btn-icon {
			border-color: #8B6F5A;
			color: #8B6F5A;
		}

			.btn-outline-success.btn-icon:hover {
				background-color: #8B6F5A;
				border-color: #8B6F5A;
				color: #fff;
			}

		.btn-outline-danger.btn-icon:hover {
			background-color: #dc3545;
			border-color: #dc3545;
		}

		.btn-outline-secondary.btn-icon:hover {
			background-color: #6c757d;
			color: #fff;
		}
	</style>
}

<div class="container my-5">
	<h2 class="mb-4 fw-bold" style="color: #8B6F5A;">
		<i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn
	</h2>

	@if (Model != null && Model.Count > 0)
	{
		<div class="mb-3">
			<h5 id="cart-count-summary" class="text-muted">
				Đang có <span id="total-qty-count" class="fw-bold text-dark">@Model.Sum(i => i.Quantity)</span> sản phẩm trong giỏ
			</h5>
		</div>

		<div class="card shadow-sm border-0 mb-4">
			<div class="card-body p-0">
				<table class="table table-striped table-hover mb-0 align-middle">
					<thead class="table-light">
						<tr>
							<th style="width:100px;">Sản phẩm</th>
							<th>Tên</th>
							<th class="text-center" style="width:180px;">Số lượng</th>
							<th class="text-end" style="width:120px;">Đơn giá</th>
							<th class="text-end" style="width:120px;">Thành tiền</th>
							<th class="text-center" style="width:80px;"></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							<tr class="cart-item-row" data-id="@item.ProductId">
								<td>
									<img src="~/product_images/@item.ProductImage"
										 alt="@item.ProductName"
										 class="img-fluid rounded-circle"
										 style="width:80px; height:80px; object-fit:cover;" />
								</td>
								<td class="fw-semibold">@item.ProductName</td>
								<td>
									<div class="d-flex justify-content-center align-items-center">
										<button type="button" class="btn btn-outline-secondary btn-icon btn-minus me-2" title="Giảm số lượng">
											<i class="fas fa-minus"></i>
										</button>

										<input type="text" name="quantity" value="@item.Quantity"
											   class="form-control form-control-sm text-center qty-input"
											   style="width:60px;" min="1" />

										<button type="button" class="btn btn-outline-secondary btn-icon btn-plus ms-2" title="Tăng số lượng">
											<i class="fas fa-plus"></i>
										</button>
									</div>
								</td>
								<td class="text-end text-muted">
									@String.Format("{0:N0}", item.Price) ₫
								</td>
								<td class="text-end fw-bold item-total">
									@String.Format("{0:N0}", item.Total) ₫
								</td>
								<td class="text-center">
									<button type="button" class="btn btn-outline-danger btn-icon" title="Xóa sản phẩm"
											onclick="updateCartItem(@item.ProductId, 0, this.closest('tr').querySelector('.qty-input'))">
										<i class="fas fa-trash-alt"></i>
									</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
			<div class="card-footer bg-white border-0">
				<div class="d-flex justify-content-between align-items-center">
					<span class="fw-bold fs-5">Tổng cộng:</span>
					<span class="fw-bold fs-4 text-danger">
						@String.Format("{0:N0}", Model.Sum(i => i.Total)) ₫
					</span>
				</div>
			</div>
		</div>

		<div class="d-flex justify-content-between align-items-center mt-4">
			<a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary px-4 py-2">
				<i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
			</a>

			<a asp-controller="Checkout" asp-action="Index" class="btn px-5 py-2 text-white fw-bold fs-6 shadow-sm" style="background: #8B6F5A; border: none;">
				Tiến hành thanh toán <i class="fas fa-arrow-right ms-2"></i>
			</a>
		</div>
	}
	else
	{
		<div class="text-center py-5 border rounded">
			<i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
			<h4 class="text-muted mb-2">Giỏ hàng của bạn đang trống</h4>
			<p class="mb-4">Hãy thêm sản phẩm vào giỏ để tiếp tục mua sắm nhé!</p>
			<a asp-action="Index" asp-controller="Home" class="btn btn-lg" style="background: #8B6F5A; color: #fff; border: none;">
				Khám phá sản phẩm
			</a>
		</div>
	}
</div>

@section Scripts {
	<script>
		function updateCartItem(productId, newQty, inputEl) {
			fetch('/Cart/UpdateCart', {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: `productId=${productId}&quantity=${newQty}`
			})
			.then(res => res.json())
			.then(data => {
				if (data.success) {
					showGlobalToast(data.message);
					if (data.removed) {
						inputEl.closest('.cart-item-row').remove();
						if (document.querySelectorAll('.cart-item-row').length === 0) location.reload();
					} else {
						inputEl.value = data.currentQty;

						let newTotal = 0;
		document.querySelectorAll('.qty-input').forEach(function(inp) {
			newTotal += parseInt(inp.value) || 0;
		});
		document.getElementById('total-qty-count').innerText = newTotal;
						// Reload trang nhẹ để cập nhật lại tổng tiền (hoặc có thể dùng JS update text)
						setTimeout(function() { location.reload(); }, 500);
					}
				} else {
					showGlobalToast(data.message, true);
					if (data.revertQty !== undefined) inputEl.value = data.revertQty;
				}
			});
		}

		document.querySelectorAll('.btn-plus').forEach(btn => {
			btn.addEventListener('click', function() {
				const row = this.closest('.cart-item-row');
				const input = row.querySelector('.qty-input');
				updateCartItem(row.getAttribute('data-id'), parseInt(input.value) + 1, input);
			});
		});

		document.querySelectorAll('.btn-minus').forEach(btn => {
			btn.addEventListener('click', function() {
				const row = this.closest('.cart-item-row');
				const input = row.querySelector('.qty-input');
				updateCartItem(row.getAttribute('data-id'), parseInt(input.value) - 1, input);
			});
		});

		document.querySelectorAll('.qty-input').forEach(input => {
			input.addEventListener('change', function() {
				updateCartItem(this.closest('.cart-item-row').getAttribute('data-id'), parseInt(this.value), this);
			});
		});
	</script>
}