@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đổi Mật Khẩu - Nội Thất Xinh</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #F8F6F3;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .wrapper {
            width: 400px;
            background: #fff;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .title {
            font-size: 30px;
            font-weight: 600;
            text-align: center;
            padding-bottom: 20px;
            color: #333;
        }

        form .field {
            height: 50px;
            width: 100%;
            margin-top: 20px;
        }

            form .field input {
                height: 100%;
                width: 100%;
                outline: none;
                padding-left: 15px;
                border-radius: 15px;
                border: 1px solid lightgrey;
                border-bottom-width: 2px;
                font-size: 16px;
                transition: all 0.3s ease;
            }

                form .field input:focus {
                    border-color: #8B6F5A;
                }

        form .btn {
            height: 50px;
            width: 100%;
            border-radius: 15px;
            position: relative;
            overflow: hidden;
            margin-top: 25px;
            padding: 0;
            border: none;
        }

            form .btn .btn-layer {
                height: 100%;
                width: 300%;
                position: absolute;
                left: -100%;
                background: #8B6F5A;
                border-radius: 15px;
                transition: all 0.4s ease;
            }

            form .btn:hover .btn-layer {
                left: 0;
            }

            form .btn input[type="submit"] {
                height: 100%;
                width: 100%;
                z-index: 1;
                position: relative;
                background: none;
                border: none;
                color: #fff;
                border-radius: 15px;
                font-size: 20px;
                font-weight: 500;
                cursor: pointer;
            }

        .alert {
            font-size: 14px;
            border-radius: 10px;
            padding: 10px;
            text-align: center;
            margin-bottom: 0;
        }

        .back-link {
            text-align: center;
            margin-top: 20px;
        }

            .back-link a {
                color: #8B6F5A;
                text-decoration: none;
            }

                .back-link a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="title">Đổi mật khẩu</div>

        <div class="mt-2">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success">@ViewBag.Success</div>
            }
        </div>

        <form action="/Account/ChangePassword" method="post">
            <div class="field">
                <input type="password" name="oldPassword" placeholder="Mật khẩu cũ" required>
            </div>
            <div class="field">
                <input type="password" name="newPassword" placeholder="Mật khẩu mới" required>
            </div>
            <div class="field">
                <input type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu mới" required>
            </div>

            <div class="field btn">
                <div class="btn-layer"></div>
                <input type="submit" value="Lưu thay đổi">
            </div>

            <div class="back-link">
                <a href="/Account/Profile">Quay lại trang cá nhân</a>
            </div>
        </form>
    </div>
</body>
</html>