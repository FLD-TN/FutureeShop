@model List<MTKPM_FE.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="mb-4 fw-bold">Đơn hàng của tôi</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-secondary text-center fs-5">
            Bạn chưa có đơn hàng nào. <a asp-controller="Home" asp-action="Index">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="order-item-row">
                        <td class="fw-bold">#@item.OrderID</td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                        <td><span class="badge bg-info text-dark">@item.OrderStatus</span></td>
                        <td>
                            <a asp-action="OrderDetail" asp-route-id="@item.OrderID" class="btn btn-sm btn-outline-primary btn-view-detail">Xem chi tiết</a>

                            @if (item.OrderStatus == "Chờ xác nhận")
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger btn-request-cancel" onclick="openCancelModal(@item.OrderID)">Yêu cầu hủy</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="modal fade" id="customerCancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Yêu cầu hủy đơn hàng</h5></div>
            <div class="modal-body">
                <input type="hidden" id="cancelOrderId" />
                <label>Lý do hủy đơn:</label>
                <textarea id="customerCancelReason" class="form-control" rows="3" placeholder="Nhập lý do bạn muốn hủy đơn..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger" id="btn-submit-customer-cancel" onclick="submitCancel()">Gửi yêu cầu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var cancelModal = new bootstrap.Modal(document.getElementById('customerCancelModal'));
        function openCancelModal(id) {
            document.getElementById('cancelOrderId').value = id;
            document.getElementById('customerCancelReason').value = '';
            cancelModal.show();
        }

        function submitCancel() {
            var id = document.getElementById('cancelOrderId').value;
            var reason = document.getElementById('customerCancelReason').value;

            fetch('/Account/RequestCancel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `orderId=${id}&reason=${encodeURIComponent(reason)}`
            }).then(res => res.json()).then(data => {
                cancelModal.hide();
                showGlobalToast(data.message, !data.success);
                if(data.success) setTimeout(() => location.reload(), 1500);
            });
        }
    </script>
}